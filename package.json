{
  "name": "onesub",
  "displayName": "OneSub — AI Buttons for Claude Code",
  "description": "One-click routine dev actions (commit message, explain, docstring) that run through your locally installed Claude Code CLI.",
  "version": "0.1.2",
  "publisher": "onesub-dev",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csexplorer/onesub-vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "claude",
    "commit message",
    "ai",
    "codegen"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "onesub.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "OneSub",
        "icon": "$(sparkle)"
      },
      {
        "command": "onesub.explainSelection",
        "title": "Explain Selection",
        "category": "OneSub"
      },
      {
        "command": "onesub.generateDocstring",
        "title": "Generate Docstring",
        "category": "OneSub"
      },
      {
        "command": "onesub.recheckHealth",
        "title": "Re-check Engine",
        "category": "OneSub"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "onesub.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/context": [
        {
          "command": "onesub.explainSelection",
          "group": "onesub@1",
          "when": "editorHasSelection"
        },
        {
          "command": "onesub.generateDocstring",
          "group": "onesub@2"
        }
      ],
      "commandPalette": [
        { "command": "onesub.generateCommitMessage" },
        { "command": "onesub.explainSelection" },
        { "command": "onesub.generateDocstring" },
        { "command": "onesub.recheckHealth" }
      ]
    },
    "configuration": {
      "title": "OneSub",
      "properties": {
        "onesub.claudePath": {
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude Code CLI executable. Leave as 'claude' if it is on your PATH."
        },
        "onesub.diffMaxLines": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Refuse to generate a commit message when the staged diff exceeds this many changed lines. 0 disables the check."
        },
        "onesub.commitConvention": {
          "type": "string",
          "enum": ["conventional", "plain"],
          "default": "conventional",
          "description": "Commit message style. 'conventional' produces Conventional Commits (feat:, fix:, ...); 'plain' produces a plain summary."
        },
        "onesub.requestTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "description": "Maximum time to wait for a Claude Code response before aborting."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "bundle": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "pretest": "tsc -p ./tsconfig.json",
    "test": "node --test out/**/*.test.js",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
